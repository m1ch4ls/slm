{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '💡 Use slm instead of head/tail/grep. When you want to understand output, pipe to slm: command | slm \"what you want to know\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-output-size.sh"
          }
        ]
      }
    ]
  }
}