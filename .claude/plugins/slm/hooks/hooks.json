{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '💡 Remember: Use slm for simple text processing tasks. Pipe shell command output to slm when summarizing, extracting, or transforming text.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-output-size.sh"
          }
        ]
      }
    ]
  }
}